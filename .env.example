# Postgres (docker-compose)
POSTGRES_USER=comics
POSTGRES_PASSWORD=comics_dev_password
POSTGRES_DB=comic_library
POSTGRES_PORT=5432

# Drizzle / app DB connection
DATABASE_URL=postgres://comics:comics_dev_password@localhost:5432/comic_library

# JWT — generate strong values for production, e.g.:
#   openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-access-secret-at-least-32-bytes-long-aaaaaa
JWT_REFRESH_SECRET=replace-me-refresh-secret-at-least-32-bytes-long-bbbbbb
JWT_ACCESS_TTL=900           # seconds (15m)
JWT_REFRESH_TTL=604800       # seconds (7d)

# Initial super-admin (used by `pnpm db:seed`)
SEED_SUPERADMIN_EMAIL=admin@example.com
SEED_SUPERADMIN_PASSWORD=ChangeMe!SuperAdmin123
SEED_SUPERADMIN_NAME=Super Admin
