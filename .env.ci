# JWT — generate strong values for production, e.g.:
#   openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-access-secret-at-least-32-bytes-long-aaaaaa
JWT_REFRESH_SECRET=replace-me-refresh-secret-at-least-32-bytes-long-bbbbbb
JWT_ACCESS_TTL=900           # seconds (15m)
JWT_REFRESH_TTL=604800       # seconds (7d)
